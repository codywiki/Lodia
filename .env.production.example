LODIA_BIND_HOST=127.0.0.1
LODIA_WEB_PORT=18080
POSTGRES_PASSWORD=replace-with-strong-password
LODIA_ADMIN_TOKEN=replace-with-admin-token
LODIA_REVIEWER_TOKEN=replace-with-reviewer-token
LODIA_CONTRIBUTOR_TOKEN=replace-with-contributor-token
LODIA_OBJECT_STORAGE_BACKEND=local
LODIA_OBJECT_STORAGE_DIR=/objects
# For Alibaba OSS/S3-compatible storage, set backend to s3 and provide:
# LODIA_S3_BUCKET=
# LODIA_S3_ENDPOINT_URL=
# LODIA_S3_REGION=cn-zhangjiakou
# LODIA_S3_PREFIX=lodia
