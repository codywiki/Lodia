LODIA_BIND_HOST=127.0.0.1
LODIA_WEB_PORT=18080

# Pull-based deployment images. For China-only production, mirror these images
# to Alibaba Cloud ACR and replace the registry host here.
LODIA_IMAGE_TAG=latest
LODIA_API_IMAGE=ghcr.io/codywiki/lodia-api:${LODIA_IMAGE_TAG}
LODIA_WORKER_IMAGE=ghcr.io/codywiki/lodia-api:${LODIA_IMAGE_TAG}
LODIA_WEB_IMAGE=ghcr.io/codywiki/lodia-web:${LODIA_IMAGE_TAG}

LODIA_ENV=production
LODIA_DEPLOYMENT_PROFILE=china_independent
LODIA_DATA_FOCUS=llm_long_horizon_task
LODIA_REGION=CN
LODIA_ALLOWED_ORIGINS=https://your-domain.example

# MySQL
MYSQL_PASSWORD=replace-with-strong-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DSN=lodia:replace-with-strong-mysql-password@tcp(mysql:3306)/lodia?parseTime=true&charset=utf8mb4&loc=UTC
MYSQL_INNODB_BUFFER_POOL_SIZE=1G
MYSQL_MAX_CONNECTIONS=800

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=512mb
LODIA_WORKER_QUEUE=ingestion
LODIA_ASYNC_PROCESSING=true

# API limits
LODIA_MAX_REQUEST_BODY_BYTES=1048576
LODIA_RATE_LIMIT_ENABLED=true
LODIA_RATE_LIMIT_REQUESTS=600
LODIA_RATE_LIMIT_WINDOW_SECONDS=60
LODIA_TRUST_PROXY_HEADERS=false
LODIA_ACCESS_LOG_ENABLED=true
LODIA_DATASET_MAX_CASES=5000

# Domestic model gateway. China production should use a domestic or private endpoint.
LODIA_MODEL_GATEWAY_MODE=http
LODIA_MODEL_GATEWAY_PROVIDER_TYPE=llm
LODIA_MODEL_GATEWAY_PROVIDER_NAME=replace-with-domestic-provider
LODIA_MODEL_GATEWAY_REGION=CN
LODIA_MODEL_GATEWAY_ENDPOINT=https://your-model-gateway.example/v1/lodia/annotate
LODIA_MODEL_GATEWAY_API_KEY=replace-with-model-gateway-key
LODIA_MODEL_GATEWAY_MODEL=replace-with-approved-model
LODIA_MODEL_GATEWAY_PROMPT_VERSION=long_horizon_task.v1
LODIA_MODEL_GATEWAY_TIMEOUT_SECONDS=15
LODIA_MODEL_GATEWAY_MAX_INPUT_CHARS=8000

# Raw data minimization
LODIA_RAW_OBJECT_TTL_HOURS=24
LODIA_PURGE_RAW_AFTER_PROCESSING=true

# Alibaba Cloud OSS object storage
LODIA_OBJECT_STORAGE_BACKEND=oss
LODIA_OBJECT_STORAGE_DIR=/objects
LODIA_OSS_ENDPOINT=https://oss-cn-zhangjiakou.aliyuncs.com
LODIA_OSS_BUCKET=replace-with-private-bucket
LODIA_OSS_PREFIX=lodia
LODIA_OSS_ACCESS_KEY_ID=replace-with-ram-access-key-id
LODIA_OSS_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
LODIA_OBJECT_STORAGE_STS_ENABLED=true
LODIA_OSS_STS_ROLE_ARN=acs:ram::your-account-id:role/your-upload-role
LODIA_OSS_STS_ENDPOINT_URL=https://sts.aliyuncs.com
LODIA_OSS_STS_SESSION_NAME=lodia-upload
LODIA_OSS_STS_DURATION_SECONDS=900
# Alternatively mount these as runtime secrets:
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# Bootstrap tokens. Use long random values and rotate through deployment secrets.
LODIA_ADMIN_TOKEN=replace-with-admin-token
LODIA_REVIEWER_TOKEN=replace-with-reviewer-token
LODIA_CONTRIBUTOR_TOKEN=replace-with-contributor-token
LODIA_PASSWORD_PEPPER=replace-with-password-pepper

PLATFORM_NET_MARGIN_RATE=0.20
