LODIA_ENV=development
LODIA_DEPLOYMENT_PROFILE=development
LODIA_DATA_FOCUS=llm_long_horizon_task
LODIA_REGION=CN
LODIA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Go API core
LODIA_HTTP_ADDR=:8080
MYSQL_DSN=lodia:lodia_dev_only@tcp(localhost:3306)/lodia?parseTime=true&charset=utf8mb4&loc=UTC
REDIS_URL=redis://localhost:6379/0
LODIA_WORKER_QUEUE=ingestion
LODIA_ASYNC_PROCESSING=true
LODIA_MAX_REQUEST_BODY_BYTES=1048576
LODIA_RATE_LIMIT_ENABLED=true
LODIA_RATE_LIMIT_REQUESTS=600
LODIA_RATE_LIMIT_WINDOW_SECONDS=60
LODIA_TRUST_PROXY_HEADERS=false
LODIA_ACCESS_LOG_ENABLED=true
LODIA_DATASET_MAX_CASES=5000

# Raw data minimization
LODIA_RAW_OBJECT_TTL_HOURS=24
LODIA_PURGE_RAW_AFTER_PROCESSING=true

# Local object storage for development. Production should use OSS.
LODIA_OBJECT_STORAGE_BACKEND=local
LODIA_OBJECT_STORAGE_DIR=storage/dev/objects
LODIA_OSS_ENDPOINT=
LODIA_OSS_BUCKET=
LODIA_OSS_PREFIX=lodia
LODIA_OSS_ACCESS_KEY_ID=
LODIA_OSS_ACCESS_KEY_SECRET=
LODIA_OBJECT_STORAGE_STS_ENABLED=false
LODIA_OSS_STS_ROLE_ARN=
LODIA_OSS_STS_ENDPOINT_URL=https://sts.aliyuncs.com
LODIA_OSS_STS_SESSION_NAME=lodia-upload
LODIA_OSS_STS_DURATION_SECONDS=900
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# Optional bootstrap tokens. Empty in development enables demo mode.
LODIA_ADMIN_TOKEN=
LODIA_REVIEWER_TOKEN=
LODIA_CONTRIBUTOR_TOKEN=
LODIA_PASSWORD_PEPPER=dev-only-password-pepper

PLATFORM_NET_MARGIN_RATE=0.20
