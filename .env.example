LODIA_ENV=development
LODIA_REGION=CN
LODIA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
POSTGRES_DSN=postgresql://lodia:lodia_dev_only@localhost:5432/lodia
REDIS_URL=redis://localhost:6379/0
LODIA_QUEUE_BACKEND=database
LODIA_RAW_OBJECT_TTL_HOURS=24
LODIA_PASSWORD_PEPPER=dev-only-pepper
PLATFORM_NET_MARGIN_RATE=0.20
LODIA_ASYNC_PROCESSING=false
LODIA_MAX_ASSET_BYTES=1048576
LODIA_UPLOAD_SESSION_TTL_SECONDS=900
LODIA_MAX_REQUEST_BODY_BYTES=1048576
LODIA_RATE_LIMIT_ENABLED=false
LODIA_RATE_LIMIT_REQUESTS=120
LODIA_RATE_LIMIT_WINDOW_SECONDS=60
LODIA_TRUST_PROXY_HEADERS=false
LODIA_REQUIRE_REQUEST_SIGNATURE=false
LODIA_REQUEST_SIGNATURE_SECRET=dev-only-signature-secret
LODIA_MAX_PAGE_LIMIT=500
LODIA_DATASET_MAX_CASES=5000
LODIA_DB_POOL_MIN_SIZE=1
LODIA_DB_POOL_MAX_SIZE=10
LODIA_OBJECT_STORAGE_BACKEND=local
LODIA_OBJECT_STORAGE_DIR=storage/dev
LODIA_S3_SSE_ALGORITHM=AES256
LODIA_S3_KMS_KEY_ID=
LODIA_ADMIN_TOKEN=change-me-admin-token
LODIA_REVIEWER_TOKEN=change-me-reviewer-token
LODIA_CONTRIBUTOR_TOKEN=change-me-contributor-token
